# counter configuration file
# All sections and keys are optional; absent keys use the built-in defaults.

[genetic]
generations     = 10    # number of evolution rounds
population_size = 200   # candidates per generation
crossover_rate  = 0.1   # probability of crossover between parents
mutation_rate   = 1.0   # probability of mutating an offspring

[fitness]
weight_syntactic = 0.2  # syntactic similarity component weight
weight_semantic  = 0.5  # semantic similarity (model counting) component weight
weight_halstead  = 0.1  # Halstead complexity penalty weight
weight_status    = 0.5  # realizability status weight

[syntactic]
weight_trigger  = 1.0   # contribution of trigger formula similarity
weight_response = 1.0   # contribution of response formula similarity
weight_timing   = 1.0   # contribution of timing constraint similarity

[mutation]
p_trigger  = 0.5    # per-requirement probability of mutating the trigger
p_response = 0.5    # per-requirement probability of mutating the response
p_timing   = 0.15   # per-requirement probability of mutating the timing

[model_counting]
default_bound = 20  # trace-length bound k for bounded model counting

[filters]
run_weakening   = true  # enable per-generation weakening filter
run_implication = true  # enable final implication maximality filter

[runtime]
black_timeout_ms = 1000  # timeout per black SAT query in milliseconds
parallel         = 8     # thread pool size (0 = hardware concurrency)
