PROJECT_NAME    = "@PROJECT_NAME@"
PROJECT_NUMBER  = "@PROJECT_VERSION@"

INPUT           = @CMAKE_SOURCE_DIR@/include
RECURSIVE       = YES
FILE_PATTERNS   = *.hpp *.h *.cpp

OUTPUT_DIRECTORY = @DOXYGEN_OUTPUT_DIR@
GENERATE_HTML   = NO
GENERATE_XML    = YES
XML_OUTPUT      = xml

EXTRACT_ALL     = YES
QUIET           = YES
