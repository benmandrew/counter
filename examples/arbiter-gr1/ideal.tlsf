INFO {
  TITLE:       "GR(1) arbiter (repaired)";
  DESCRIPTION: "Two-client mutual-exclusion arbiter with request-fairness assumptions";
  SEMANTICS:   Mealy;
  TARGET:      Mealy;
}

MAIN {
  INPUTS {
    r0;
    r1;
  }
  OUTPUTS {
    g0;
    g1;
  }
  ASSUME {
    G F r0;
    G F r1;
  }
  GUARANTEE {
    G (g0 -> r0);
    G (g1 -> r1);
    G !(g0 & g1);
    G F g0;
    G F g1;
  }
}
